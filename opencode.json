{
  "$schema": "https://opencode.ai/config.json",
  "permission": "allow",
  "autoshare": false,
  "autoCompact": true,
  "providers": {
    "google": {
      "apiKey": "${GEMINI_API_KEY}"
    },
    "anthropic": {
      "apiKey": "${ANTHROPIC_API_KEY}"
    },
    "openai": {
      "apiKey": "${OPENAI_API_KEY}"
    },
    "openrouter": {
      "name": "OpenRouter",
      "apiKey": "${OPENROUTER_API_KEY}",
      "models": {
        "anthropic/claude-sonnet-4-5": {},
        "google/gemini-2.5-pro": {},
        "openai/gpt-4o": {}
      }
    }
  },
  "agents": {
    "coder": {
      "model": "google/gemini-2.5-pro",
      "maxTokens": 8000
    },
    "task": {
      "model": "google/gemini-2.5-flash",
      "maxTokens": 4000
    },
    "title": {
      "model": "google/gemini-2.5-flash",
      "maxTokens": 80
    }
  },
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ],
      "enabled": false
    },
    "git": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-server-git",
        "--repository",
        "."
      ],
      "enabled": false
    },
    "memory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "enabled": false
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": false
    },
    "fetch": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-server-fetch"
      ],
      "enabled": false
    },
    "time": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-server-time"
      ],
      "enabled": false
    },
    "sqlite": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-sqlite",
        "--db-path",
        "./data.db"
      ],
      "enabled": false
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": false,
      "environment": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      }
    },
    "brave-search": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@brave/brave-search-mcp-server"
      ],
      "enabled": false,
      "environment": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      }
    },
    "exa": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "exa-mcp-server"
      ],
      "enabled": false,
      "environment": {
        "EXA_API_KEY": "${EXA_API_KEY}"
      }
    },
    "tavily": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "tavily-mcp"
      ],
      "enabled": false,
      "environment": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      }
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp"
      ],
      "enabled": false
    },
    "puppeteer": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-puppeteer"
      ],
      "enabled": false
    },
    "docker": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-server-docker"
      ],
      "enabled": false
    },
    "mermaid": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@narasimhaponnada/mermaid-mcp-server"
      ],
      "enabled": false
    },
    "yt-dlp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@kevinwatt/yt-dlp-mcp"
      ],
      "enabled": false
    },
    "python-analysis": {
      "type": "local",
      "command": [
        "uvx",
        "python-lsp-mcp"
      ],
      "enabled": false,
      "environment": {
        "PROJECT_PATH": "."
      }
    },
    "github": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "enabled": false,
      "environment": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "upstash": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/mcp-server"
      ],
      "enabled": false,
      "environment": {
        "UPSTASH_REDIS_REST_URL": "${UPSTASH_REDIS_REST_URL}",
        "UPSTASH_REDIS_REST_TOKEN": "${UPSTASH_REDIS_REST_TOKEN}",
        "QSTASH_TOKEN": "${QSTASH_TOKEN}"
      }
    },
    "qdrant": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-server-qdrant"
      ],
      "enabled": false,
      "environment": {
        "QDRANT_URL": "${QDRANT_URL}",
        "QDRANT_API_KEY": "${QDRANT_API_KEY}",
        "COLLECTION_NAME": "antigravity-agent-memory",
        "EMBEDDING_PROVIDER": "fastembed"
      }
    },
    "daytona": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@daytona/mcp"
      ],
      "enabled": false,
      "environment": {
        "DAYTONA_API_KEY": "${DAYTONA_API_KEY}",
        "DAYTONA_SERVER_URL": "${DAYTONA_SERVER_URL}"
      }
    },
    "n8n": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "n8n-mcp"
      ],
      "enabled": false,
      "environment": {
        "N8N_API_KEY": "${N8N_API_KEY}",
        "N8N_BASE_URL": "${N8N_BASE_URL}"
      }
    },
    "postgres": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "postgresql-mcp"
      ],
      "enabled": false,
      "environment": {
        "POSTGRES_CONNECTION_STRING": "${POSTGRES_CONNECTION_STRING}"
      }
    },
    "firecrawl": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "firecrawl-mcp"
      ],
      "enabled": false,
      "environment": {
        "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}"
      }
    },
    "agentops": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "agentops-mcp"
      ],
      "enabled": false,
      "environment": {
        "AGENTOPS_API_KEY": "${AGENTOPS_API_KEY}"
      }
    },
    "chroma": {
      "type": "local",
      "command": [
        "uvx",
        "chroma-mcp",
        "--mode",
        "embedded",
        "--data-dir",
        "./.chroma"
      ],
      "enabled": false
    },
    "taskmaster-ai": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "--package=task-master-ai",
        "task-master-ai"
      ],
      "enabled": false,
      "environment": {
        "GEMINI_API_KEY": "${GEMINI_API_KEY}"
      }
    },
    "neon": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@neondatabase/mcp-server-neon"
      ],
      "enabled": false,
      "environment": {
        "NEON_API_KEY": "${NEON_API_KEY}"
      }
    },
    "openrouter": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "openrouter-mcp"
      ],
      "enabled": false,
      "environment": {
        "OPENROUTER_API_KEY": "${OPENROUTER_API_KEY}"
      }
    },
    "linear": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "linear-mcp-server"
      ],
      "enabled": false,
      "environment": {
        "LINEAR_API_KEY": "${LINEAR_API_KEY}"
      }
    },
    "notion": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@notionhq/notion-mcp-server"
      ],
      "enabled": false,
      "environment": {
        "NOTION_API_KEY": "${NOTION_API_KEY}"
      }
    },
    "docker-agent-gateway": {
      "type": "sse",
      "url": "http://localhost:3000/api/control/stream",
      "enabled": true,
      "description": "Docker Open Agent Gateway (sandboxed.sh/docker-mcp multiplexer)"
    }
  }
}
