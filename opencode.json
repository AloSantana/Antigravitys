    "time": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-time"],
      "enabled": true
    },
    "sqlite": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sqlite", "--db-path", "./data.db"],
      "enabled": true
