{
  "$schema": "https://opencode.ai/config.json",
  "permission": "allow",
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ],
      "enabled": false
    },
    "git": {
      "type": "local",
      "command": [
        "C:\\Users\\primo\\.local\\bin\\uvx.exe",
        "mcp-server-git",
        "--repository",
        "."
      ],
      "enabled": false
    },
    "memory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "enabled": false
