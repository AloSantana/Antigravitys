# Copy this file to .env and fill in your values

# ═══ AI Models ═══
# Gemini API Key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Multiple Gemini API Keys (comma-separated for rotation)
# Use this for swarm operations with multiple concurrent agents
# Example: key1,key2,key3
GEMINI_API_KEYS=

# Vertex AI Configuration (Google Cloud)
# Get API key from: https://console.cloud.google.com/apis/credentials
VERTEX_API_KEY=your_vertex_api_key_here
# Or use service account JSON file path instead of API key
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Multiple Vertex AI Keys (comma-separated for rotation)
VERTEX_API_KEYS=

# Vertex AI Project Settings
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-pro

# OpenAI API Key (for OpenAI-compatible endpoints)
OPENAI_API_KEY=

# Multiple OpenAI Keys (comma-separated for rotation)
OPENAI_API_KEYS=

# OpenRouter API Key (access to 100+ models from one API)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Multiple OpenRouter Keys (comma-separated for rotation)
# OpenRouter provides access to: Claude, GPT-4, Gemini, Llama, Mixtral, and more
OPENROUTER_API_KEYS=

# OpenRouter Default Model (see https://openrouter.ai/models for full list)
# Popular options:
# - anthropic/claude-3.5-sonnet (best quality)
# - openai/gpt-4-turbo (balanced)
# - google/gemini-pro-1.5 (fast)
# - meta-llama/llama-3.1-70b-instruct (open source)
# - mistralai/mixtral-8x7b-instruct (cost-effective)
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Local Model Settings (if using Ollama)
LOCAL_MODEL=llama3

# Active AI Model Selection
# Options: 'gemini', 'vertex', 'ollama', 'openrouter', 'auto'
# - gemini: Always use Google Gemini
# - vertex: Always use Google Vertex AI
# - ollama: Use local Ollama with cloud fallback
# - openrouter: Use OpenRouter (access to 100+ models)
# - auto: Automatic selection based on complexity (default)
ACTIVE_MODEL=auto

# ═══ Model Rotator Settings ═══
# Enable intelligent API key rotation (true/false)
MODEL_ROTATOR_ENABLED=true

# Automatic key rotation for swarm operations (true/false)
SWARM_AUTO_ROTATE_KEYS=true

# Smart rate limit handoffs (automatically switch keys on rate limit)
SMART_RATE_LIMIT_HANDOFF=true

# ═══ GitHub Integration ═══
# GitHub Token for MCP (get from https://github.com/settings/tokens)
# Required scopes: repo, read:org
COPILOT_MCP_GITHUB_TOKEN=your_github_token_here

# ═══ Optional Services ═══
# Brave Search API (get from https://brave.com/search/api/)
COPILOT_MCP_BRAVE_API_KEY=

# PostgreSQL connection string
COPILOT_MCP_POSTGRES_CONNECTION_STRING=

# ═══ Server Configuration ═══
HOST=0.0.0.0
PORT=8000

# ═══ Remote Access Configuration ═══
# Enable remote access mode (true/false)
REMOTE_ACCESS=false

# External host/IP for remote access (your VPS IP or domain)
# Example: 192.168.1.100 or yourdomain.com
EXTERNAL_HOST=

# Frontend port (if using separate frontend server)
FRONTEND_PORT=3000

# Backend port
BACKEND_PORT=8000

# ═══ Ngrok Tunnel Configuration ═══
# Enable ngrok tunnel for public URL access (true/false)
NGROK_ENABLED=false

# Ngrok auth token (get from https://dashboard.ngrok.com/get-started/your-authtoken)
# Required for advanced features like custom domains and longer sessions
NGROK_AUTH_TOKEN=

# Ngrok region (us, eu, ap, au, sa, jp, in)
NGROK_REGION=us

# Custom domain (requires paid ngrok plan)
NGROK_DOMAIN=

# ═══ Security Settings ═══
# Comma-separated list of allowed CORS origins
# For remote access, add: http://your-vps-ip:3000,http://your-vps-ip:8000
# For wildcard access (development only): *
# Example: http://localhost:3000,http://localhost:8000,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000

# Maximum file upload size in bytes (default: 10MB)
MAX_FILE_SIZE=10485760

# Maximum message length for WebSocket/API (default: 10000 chars)
MAX_MESSAGE_LENGTH=10000

# ═══ RAG & Ingestion Settings ═══
# Maximum file size for RAG ingestion in MB (default: 10MB)
RAG_MAX_FILE_SIZE_MB=10

# Maximum chunk size for document splitting (default: 2000 characters)
RAG_MAX_CHUNK_SIZE=2000

# Chunk overlap for context preservation (default: 200 characters)
RAG_CHUNK_OVERLAP=200

# Number of files to process concurrently (default: 5)
RAG_BATCH_SIZE=5

# Memory warning threshold in MB (default: 500MB)
RAG_MEMORY_WARNING_MB=500

# Maximum concurrent embeddings to prevent resource exhaustion (default: 10)
RAG_MAX_CONCURRENT_EMBEDDINGS=10

# ═══ Performance & Caching Settings ═══
# Response cache TTL in seconds (default: 300 = 5 minutes)
CACHE_TTL_SECONDS=300

# Maximum number of cached responses (default: 100)
CACHE_MAX_SIZE=100

# Vector query cache TTL in seconds (default: 60)
VECTOR_QUERY_CACHE_TTL=60

# Maximum number of cached vector queries (default: 50)
VECTOR_QUERY_CACHE_SIZE=50

# ═══ Advanced Settings ═══
# Debug mode (true/false)
DEBUG_MODE=false

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Agent settings
AGENT_NAME=AntigravityAgent
MAX_ITERATIONS=10

# Database
DB_PATH=./data.db

# Logging
LOG_LEVEL=INFO

# ═══ Added for Testing ═══
SSL_ENABLED=false
SSL_CERT_PATH=certs/server.crt
SSL_KEY_PATH=certs/server.key
NGROK_URL=
GCP_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
DEBUG_LOG_LEVEL=DEBUG
DEBUG_MAX_LOG_SIZE_MB=10

# ═══ OpenCode & Multi-Agent MCP Servers ═══
# Taskmaster AI — AI-driven task management for multi-agent sprints
ANTHROPIC_API_KEY=sk-ant-...

# Tavily — AI-optimized search for agent RAG pipelines
TAVILY_API_KEY=tvly-...

# Neon — Serverless Postgres with database branching for agents
NEON_API_KEY=

# OpenRouter — Unified access to 200+ AI models for multi-agent routing
OPENROUTER_API_KEY=sk-or-v1-...

# Upstash — Redis (cross-session state) + QStash (async agent message queue)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...
QSTASH_TOKEN=eyJ...

# Qdrant — Production vector database for agent semantic memory
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Linear — Issue and sprint tracking for agent coordination
LINEAR_API_KEY=lin_api_...

# Notion — Official Notion knowledge base and auto-documentation
NOTION_API_KEY=secret_...

# Daytona — Persistent dev environment sandboxes for multi-session agents
DAYTONA_API_KEY=dt-...
DAYTONA_SERVER_URL=https://app.daytona.io
