{
  "$schema": "https://modelcontextprotocol.io/schema/mcp.json",
  "description": "Enhanced MCP server configuration for GitHub Copilot - Antigravity Workspace Template. Includes 20+ servers for agents, multi-agents, coding, search, browser automation, and AI model bridges. See docs/MCP_SERVERS_CATALOG.md for the full catalog of 100+ servers.",
  "mcpServers": {
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."],
      "tools": ["read_file", "read_multiple_files", "write_file", "edit_file", "create_directory", "list_directory", "move_file", "search_files", "get_file_info", "list_allowed_directories"]
    },
    "git": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-git", "--repository", "."],
      "tools": ["git_status", "git_diff", "git_commit", "git_add", "git_reset", "git_log", "git_show", "git_branch", "git_checkout", "git_clone"]
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@github/mcp-server"],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      },
      "tools": ["get_file_contents", "get_issue", "get_pull_request", "list_issues", "list_pull_requests", "search_code", "search_issues", "search_repositories", "create_issue", "create_pull_request", "update_issue", "create_or_update_file", "push_files", "create_branch", "list_commits", "list_branches"]
    },
    "memory": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "tools": ["create_entities", "create_relations", "add_observations", "delete_entities", "delete_observations", "delete_relations", "read_graph", "search_nodes", "open_nodes"]
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "tools": ["sequentialthinking"]
    },
    "fetch": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-fetch"],
      "tools": ["fetch"]
    },
    "sqlite": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sqlite", "--db-path", "resources/config/downloads.db"],
      "tools": ["read_query", "write_query", "create_table", "list_tables", "describe_table", "append_insight"]
    },
    "python-analysis": {
      "type": "stdio",
      "command": "python",
      "args": ["-m", "mcp_server_python_analysis"],
      "env": {
        "PROJECT_PATH": "."
      },
      "tools": ["run_mypy", "analyze_complexity", "find_imports", "get_definitions"]
    },
    "docker": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "mcp-server-docker"],
      "tools": ["list_containers", "create_container", "run_container", "stop_container", "remove_container", "list_images", "pull_image", "build_image", "run_exec"]
    },
    "time": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-time"]
    },
    "puppeteer": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@anthropic/server-puppeteer"],
      "tools": ["puppeteer_navigate", "puppeteer_screenshot", "puppeteer_click", "puppeteer_fill", "puppeteer_select", "puppeteer_hover", "puppeteer_evaluate"]
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@playwright/mcp"],
      "tools": ["browser_navigate", "browser_screenshot", "browser_click", "browser_fill", "browser_select_option", "browser_hover", "browser_evaluate", "browser_close", "browser_snapshot", "browser_type", "browser_wait_for"]
    },
    "yt-dlp": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "mcp-server-yt-dlp"],
      "tools": ["download_video", "get_video_info", "list_formats", "extract_audio"]
    },
    "brave-search": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@brave/brave-search-mcp"],
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      },
      "tools": ["brave_web_search", "brave_local_search"]
    },
    "postgres": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "mcp-server-postgres"],
      "env": {
        "POSTGRES_CONNECTION_STRING": "${POSTGRES_CONNECTION_STRING}"
      },
      "tools": ["query", "execute", "list_tables", "describe_table"]
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "env": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      },
      "tools": ["resolve-library-id", "get-library-docs"]
    },
    "exa": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "exa-mcp-server"],
      "env": {
        "EXA_API_KEY": "${EXA_API_KEY}"
      },
      "tools": ["search", "find_similar", "get_contents", "search_and_contents"]
    },
    "mermaid": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@narasimhaponnada/mermaid-mcp-server"],
      "tools": ["generate_diagram", "validate_mermaid", "list_diagram_types"]
    },
    "firecrawl": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "firecrawl-mcp"],
      "env": {
        "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}"
      },
      "tools": ["scrape", "crawl", "search", "map", "extract"]
    },
    "agentops": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "agentops-mcp"],
      "env": {
        "AGENTOPS_API_KEY": "${AGENTOPS_API_KEY}"
      },
      "tools": ["start_session", "end_session", "log_event", "log_error", "get_analytics"]
    }
  }
}
