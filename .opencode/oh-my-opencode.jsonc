{
  "agents": {
    "sisyphus": {
      "mode": "primary",
      "model": "anthropic/claude-opus-4-6",
      "maxTokens": 64000,
      "thinking": {
        "type": "enabled", "budget": 32000
      }
    },
    "oracle": {
      "model": "anthropic/claude-opus-4-6",
      "mode": "subagent"
    },
    "librarian": {
      "model": "anthropic/claude-sonnet-4-6",
      "mode": "subagent"
    },
    "explore": {
      "model": "anthropic/claude-haiku-4-5",
      "mode": "subagent"
    },
    "hephaestus": {
      "model": "anthropic/claude-sonnet-4-6",
      "mode": "subagent"
    },
    "prometheus": {
      "model": "google/gemini-2.5-flash",
      "mode": "subagent"
    },
    "multimodal-looker": {
      "model": "google/gemini-2.5-pro",
      "mode": "subagent"
    }
  },
  "categories": {
    "ultrabrain": {
      "model": "anthropic/claude-opus-4-6",
      "maxTokens": 64000,
      "thinking": {
        "type": "enabled", "budget": 32000
      }
    },
    "visual-engineering": {
      "model": "anthropic/claude-sonnet-4-6"
    },
    "quick": {
      "model": "anthropic/claude-haiku-4-5",
      "maxTokens": 4000
    },
    "writing": {
      "model": "google/gemini-2.5-flash"
    }
  },
  "disabled_skills": [],
  "mcps": {
    "websearch": {
      "enabled": true,
      "exa_api_key": "${EXA_API_KEY}",
      "tavily_api_key": "${TAVILY_API_KEY}"
    },
    "context7": {
      "enabled": true
    },
    "grep_app": {
      "enabled": true
    }
  },
  "background_agent": {
    "enabled": true,
    "max_concurrent": 5
  },
  "tmux": {
    "enabled": true
  },
  "skill_loader": {
    "enabled": true,
    "paths": [
      ".opencode/skills"
    ]
  },
  "disabled_hooks": [],
  "disabled_tools": [],
  "disabled_commands": [],
  "_migrations": [
    "model-version:anthropic/claude-opus-4-5->anthropic/claude-opus-4-6",
    "model-version:anthropic/claude-opus-4-5->anthropic/claude-opus-4-6",
    "model-version:anthropic/claude-sonnet-4-5->anthropic/claude-sonnet-4-6",
    "model-version:anthropic/claude-sonnet-4-5->anthropic/claude-sonnet-4-6",
    "model-version:anthropic/claude-opus-4-5->anthropic/claude-opus-4-6",
    "model-version:anthropic/claude-sonnet-4-5->anthropic/claude-sonnet-4-6"
  ]
}
