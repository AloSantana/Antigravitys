{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "servers": {
      "agentgateway-primary": {
        "type": "http",
        "url": "http://localhost:15000/mcp/http",
        "enabled": true,
        "description": "Primary AgentGateway instance"
      },
      "agentgateway-backup": {
        "type": "sse",
        "url": "http://localhost:15001/mcp/sse",
        "enabled": false,
        "description": "Backup gateway using SSE transport"
      },
      "local-playwright": {
        "type": "stdio",
        "command": "npx",
        "args": ["-y", "@playwright/mcp-server"],
        "enabled": true,
        "description": "Local Playwright MCP server"
      }
    }
  }
}
