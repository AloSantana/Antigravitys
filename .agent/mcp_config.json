{
  "_readme": "See docs/MCP_SERVERS_CATALOG.md for full list. docs/MCP_INSTALLATION_PROMPTS.md for setup prompts. docs/MCP_INTEGRATION_GUIDE.md for integration guide.",
  "_gemini_setup": "Copy mcpServers entries to ~/.gemini/settings.json for Gemini CLI integration",
  "_opencode_setup": "Copy mcpServers entries to ~/.opencode.json (or .opencode.json local) for OpenCode/Crush CLI integration",
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      },
      "enabled": false
    },
    "shadcn": {
      "command": "npx",
      "args": [
        "shadcn@latest",
        "mcp"
      ],
      "enabled": false
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ],
      "enabled": false
    },
    "git": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-git",
        "--repository",
        "."
      ],
      "enabled": false
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@github/mcp-server"
      ],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      },
      "enabled": false
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "enabled": false
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": false
    },
    "fetch": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-fetch"
      ],
      "enabled": false
    },
    "time": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-time"
      ],
      "enabled": false
    },
    "brave-search": {
      "command": "npx",
      "args": [
        "-y",
        "@brave/brave-search-mcp"
      ],
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      },
      "enabled": false
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp"
      ],
      "enabled": false
    },
    "exa": {
      "command": "npx",
      "args": [
        "-y",
        "exa-mcp-server"
      ],
      "env": {
        "EXA_API_KEY": "${EXA_API_KEY}"
      },
      "enabled": false
    },
    "mermaid": {
      "command": "npx",
      "args": [
        "-y",
        "@narasimhaponnada/mermaid-mcp-server"
      ],
      "enabled": false
    },
    "firecrawl": {
      "command": "npx",
      "args": [
        "-y",
        "firecrawl-mcp"
      ],
      "env": {
        "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}"
      },
      "enabled": false
    },
    "agentops": {
      "command": "npx",
      "args": [
        "-y",
        "agentops-mcp"
      ],
      "env": {
        "AGENTOPS_API_KEY": "${AGENTOPS_API_KEY}"
      },
      "enabled": false
    },
    "docker": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-docker"
      ],
      "enabled": false
    },
    "sqlite": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sqlite",
        "--db-path",
        "resources/config/downloads.db"
      ],
      "enabled": false
    },
    "docker-agent-gateway": {
      "type": "sse",
      "url": "http://localhost:3000/api/control/stream",
      "enabled": true,
      "description": "Docker Open Agent Gateway (sandboxed.sh/docker-mcp multiplexer)"
    }
  }
}