{
  "_comment": "OpenCode/Crush MCP config template. Copy this to ~/.opencode.json or .opencode.json (project-local).",
  "_source": "Generated by Antigravity Workspace — see ANTIGRAVITY_MASTER_GUIDE.md",

  "providers": {
    "anthropic": {
      "apiKey": "${ANTHROPIC_API_KEY}",
      "disabled": false
    },
    "google": {
      "apiKey": "${GEMINI_API_KEY}",
      "disabled": false
    },
    "openrouter": {
      "apiKey": "${OPENROUTER_API_KEY}",
      "disabled": false
    }
  },

  "agents": {
    "coder": {
      "model": "gemini-2.5-pro",
      "maxTokens": 8000
    },
    "task": {
      "model": "gemini-2.5-flash",
      "maxTokens": 4000
    },
    "title": {
      "model": "gemini-2.5-flash",
      "maxTokens": 80
    }
  },

  "mcpServers": {

    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."],
      "env": []
    },

    "git": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-git", "--repository", "."],
      "env": []
    },

    "github": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@github/mcp-server"],
      "env": [{"name": "GITHUB_TOKEN", "value": "${GITHUB_TOKEN}"}]
    },

    "memory": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "env": []
    },

    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "env": []
    },

    "fetch": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-fetch"],
      "env": []
    },

    "time": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-time"],
      "env": []
    },

    "sqlite": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sqlite", "--db-path", "./data.db"],
      "env": []
    },

    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@playwright/mcp", "--headless"],
      "env": []
    },

    "mermaid": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@narasimhaponnada/mermaid-mcp-server"],
      "env": []
    },

    "docker": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "mcp-server-docker"],
      "env": []
    },

    "tavily": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@tavily/mcp"],
      "env": [{"name": "TAVILY_API_KEY", "value": "${TAVILY_API_KEY}"}]
    },

    "brave-search": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@brave/brave-search-mcp"],
      "env": [{"name": "BRAVE_API_KEY", "value": "${BRAVE_API_KEY}"}]
    },

    "exa": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "exa-mcp-server"],
      "env": [{"name": "EXA_API_KEY", "value": "${EXA_API_KEY}"}]
    },

    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "env": [{"name": "CONTEXT7_API_KEY", "value": "${CONTEXT7_API_KEY}"}]
    },

    "upstash": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/mcp-server"],
      "env": [
        {"name": "UPSTASH_REDIS_REST_URL",   "value": "${UPSTASH_REDIS_REST_URL}"},
        {"name": "UPSTASH_REDIS_REST_TOKEN", "value": "${UPSTASH_REDIS_REST_TOKEN}"},
        {"name": "QSTASH_TOKEN",             "value": "${QSTASH_TOKEN}"}
      ]
    },

    "qdrant": {
      "type": "stdio",
      "command": "uvx",
      "args": ["mcp-server-qdrant"],
      "env": [
        {"name": "QDRANT_URL",         "value": "${QDRANT_URL}"},
        {"name": "QDRANT_API_KEY",     "value": "${QDRANT_API_KEY}"},
        {"name": "COLLECTION_NAME",    "value": "antigravity-agent-memory"},
        {"name": "EMBEDDING_PROVIDER", "value": "fastembed"}
      ]
    },

    "daytona": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@daytona/mcp"],
      "env": [
        {"name": "DAYTONA_API_KEY",    "value": "${DAYTONA_API_KEY}"},
        {"name": "DAYTONA_SERVER_URL", "value": "${DAYTONA_SERVER_URL}"}
      ]
    },

    "n8n": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@n8n/mcp-server"],
      "env": [
        {"name": "N8N_API_KEY",  "value": "${N8N_API_KEY}"},
        {"name": "N8N_BASE_URL", "value": "${N8N_BASE_URL}"}
      ]
    }
  },

  "autoCompact": true,
  "debug": false
}
