{
  "_comment": "OpenCode/Crush MCP config template. Copy this to ~/.opencode.json or .opencode.json (project-local)",
  "_source": "Generated by Antigravity Workspace - docs/MCP_INTEGRATION_GUIDE.md",
  "providers": {
    "anthropic": {
      "apiKey": "${ANTHROPIC_API_KEY}",
      "disabled": false
    },
    "google": {
      "apiKey": "${GEMINI_API_KEY}",
      "disabled": false
    },
    "openrouter": {
      "apiKey": "${OPENROUTER_API_KEY}",
      "disabled": false
    }
  },
  "agents": {
    "coder": {
      "model": "gemini-2.5-pro",
      "maxTokens": 8000
    },
    "task": {
      "model": "gemini-2.5-flash",
      "maxTokens": 4000
    },
    "title": {
      "model": "gemini-2.5-flash",
      "maxTokens": 80
    }
  },
  "mcpServers": {
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."],
      "env": []
    },
    "git": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-git", "--repository", "."],
      "env": []
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@github/mcp-server"],
      "env": [{"name": "GITHUB_TOKEN", "value": "${GITHUB_TOKEN}"}]
    },
    "memory": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "env": []
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "env": []
    },
    "fetch": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-fetch"],
      "env": []
    },
    "time": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-time"],
      "env": []
    },
    "brave-search": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@brave/brave-search-mcp"],
      "env": [{"name": "BRAVE_API_KEY", "value": "${BRAVE_API_KEY}"}]
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "env": [{"name": "CONTEXT7_API_KEY", "value": "${CONTEXT7_API_KEY}"}]
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@playwright/mcp"],
      "env": []
    },
    "exa": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "exa-mcp-server"],
      "env": [{"name": "EXA_API_KEY", "value": "${EXA_API_KEY}"}]
    },
    "mermaid": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@narasimhaponnada/mermaid-mcp-server"],
      "env": []
    },
    "sqlite": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sqlite", "--db-path", "./data.db"],
      "env": []
    }
  },
  "autoCompact": true,
  "debug": false
}
