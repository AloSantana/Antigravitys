{
  "_comment": "OpenCode/Crush MCP config template. Copy this to ~/.opencode.json or .opencode.json (project-local).",
  "_source": "Generated by Antigravity Workspace \u2014 see ANTIGRAVITY_MASTER_GUIDE.md",
  "providers": {
    "anthropic": {
      "apiKey": "${ANTHROPIC_API_KEY}",
      "disabled": false
    },
    "google": {
      "apiKey": "${GEMINI_API_KEY}",
      "disabled": false
    },
    "openrouter": {
      "apiKey": "${OPENROUTER_API_KEY}",
      "disabled": false
    }
  },
  "agents": {
    "coder": {
      "model": "gemini-2.5-pro",
      "maxTokens": 8000
    },
    "task": {
      "model": "gemini-2.5-flash",
      "maxTokens": 4000
    },
    "title": {
      "model": "gemini-2.5-flash",
      "maxTokens": 80
    }
  },
  "mcpServers": {
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ],
      "env": [],
      "enabled": false
    },
    "git": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-git",
        "--repository",
        "."
      ],
      "env": [],
      "enabled": false
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@github/mcp-server"
      ],
      "env": [
        {
          "name": "GITHUB_TOKEN",
          "value": "${GITHUB_TOKEN}"
        }
      ],
      "enabled": false
    },
    "memory": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "env": [],
      "enabled": false
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "env": [],
      "enabled": false
    },
    "fetch": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-fetch"
      ],
      "env": [],
      "enabled": false
    },
    "time": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-time"
      ],
      "env": [],
      "enabled": false
    },
    "sqlite": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sqlite",
        "--db-path",
        "./data.db"
      ],
      "env": [],
      "enabled": false
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp",
        "--headless"
      ],
      "env": [],
      "enabled": false
    },
    "mermaid": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@narasimhaponnada/mermaid-mcp-server"
      ],
      "env": [],
      "enabled": false
    },
    "docker": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-docker"
      ],
      "env": [],
      "enabled": false
    },
    "tavily": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@tavily/mcp"
      ],
      "env": [
        {
          "name": "TAVILY_API_KEY",
          "value": "${TAVILY_API_KEY}"
        }
      ],
      "enabled": false
    },
    "brave-search": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@brave/brave-search-mcp"
      ],
      "env": [
        {
          "name": "BRAVE_API_KEY",
          "value": "${BRAVE_API_KEY}"
        }
      ],
      "enabled": false
    },
    "exa": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "exa-mcp-server"
      ],
      "env": [
        {
          "name": "EXA_API_KEY",
          "value": "${EXA_API_KEY}"
        }
      ],
      "enabled": false
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": [
        {
          "name": "CONTEXT7_API_KEY",
          "value": "${CONTEXT7_API_KEY}"
        }
      ],
      "enabled": false
    },
    "upstash": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/mcp-server"
      ],
      "env": [
        {
          "name": "UPSTASH_REDIS_REST_URL",
          "value": "${UPSTASH_REDIS_REST_URL}"
        },
        {
          "name": "UPSTASH_REDIS_REST_TOKEN",
          "value": "${UPSTASH_REDIS_REST_TOKEN}"
        },
        {
          "name": "QSTASH_TOKEN",
          "value": "${QSTASH_TOKEN}"
        }
      ],
      "enabled": false
    },
    "qdrant": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "mcp-server-qdrant"
      ],
      "env": [
        {
          "name": "QDRANT_URL",
          "value": "${QDRANT_URL}"
        },
        {
          "name": "QDRANT_API_KEY",
          "value": "${QDRANT_API_KEY}"
        },
        {
          "name": "COLLECTION_NAME",
          "value": "antigravity-agent-memory"
        },
        {
          "name": "EMBEDDING_PROVIDER",
          "value": "fastembed"
        }
      ],
      "enabled": false
    },
    "daytona": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@daytona/mcp"
      ],
      "env": [
        {
          "name": "DAYTONA_API_KEY",
          "value": "${DAYTONA_API_KEY}"
        },
        {
          "name": "DAYTONA_SERVER_URL",
          "value": "${DAYTONA_SERVER_URL}"
        }
      ],
      "enabled": false
    },
    "n8n": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@n8n/mcp-server"
      ],
      "env": [
        {
          "name": "N8N_API_KEY",
          "value": "${N8N_API_KEY}"
        },
        {
          "name": "N8N_BASE_URL",
          "value": "${N8N_BASE_URL}"
        }
      ],
      "enabled": false
    },
    "docker-agent-gateway": {
      "type": "sse",
      "url": "http://localhost:3000/api/control/stream",
      "enabled": true,
      "description": "Docker Open Agent Gateway (sandboxed.sh/docker-mcp multiplexer)"
    }
  },
  "autoCompact": true,
  "debug": false
}