{
  "mcpServers": {
    "filesystem": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ],
      "enabled": false,
      "description": "File system operations"
    },
    "git": {
      "transport": "stdio",
      "command": "uvx",
      "args": [
        "mcp-server-git",
        "--repository",
        "."
      ],
      "enabled": false
    },
    "memory": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "enabled": false,
      "description": "Persistent agent memory"
    },
    "sequential-thinking": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": false,
      "description": "Step-by-step reasoning"
    },
    "fetch": {
      "transport": "stdio",
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ],
      "enabled": false
    },
    "time": {
      "transport": "stdio",
      "command": "uvx",
      "args": [
        "mcp-server-time"
      ],
      "enabled": false
    },
    "sqlite": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "mcp-sqlite",
        "--db-path",
        "./data.db"
      ],
      "enabled": false,
      "description": "SQLite database operations"
    },
    "context7": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      },
      "enabled": false,
      "description": "Up-to-date library documentation"
    },
    "brave-search": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@brave/brave-search-mcp-server"
      ],
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      },
      "enabled": false,
      "description": "Web search using Brave Search API"
    },
    "exa": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "exa-mcp-server"
      ],
      "env": {
        "EXA_API_KEY": "${EXA_API_KEY}"
      },
      "enabled": false,
      "description": "Neural semantic search"
    },
    "tavily": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "tavily-mcp"
      ],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      },
      "enabled": false,
      "description": "AI-optimized web search"
    },
    "playwright": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp"
      ],
      "enabled": false,
      "description": "Browser automation with Playwright"
    },
    "puppeteer": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-puppeteer"
      ],
      "enabled": false
    },
    "docker": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-docker"
      ],
      "enabled": false
    },
    "mermaid": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@narasimhaponnada/mermaid-mcp-server"
      ],
      "enabled": false
    },
    "yt-dlp": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@kevinwatt/yt-dlp-mcp"
      ],
      "enabled": false
    },
    "python-analysis": {
      "transport": "stdio",
      "command": "uvx",
      "args": [
        "python-lsp-mcp"
      ],
      "env": {
        "PROJECT_PATH": "."
      },
      "enabled": false
    },
    "github": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      },
      "enabled": false
    },
    "upstash": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/mcp-server"
      ],
      "env": {
        "UPSTASH_REDIS_REST_URL": "${UPSTASH_REDIS_REST_URL}",
        "UPSTASH_REDIS_REST_TOKEN": "${UPSTASH_REDIS_REST_TOKEN}",
        "QSTASH_TOKEN": "${QSTASH_TOKEN}"
      },
      "enabled": false
    },
    "qdrant": {
      "transport": "stdio",
      "command": "uvx",
      "args": [
        "mcp-server-qdrant"
      ],
      "env": {
        "QDRANT_URL": "${QDRANT_URL}",
        "QDRANT_API_KEY": "${QDRANT_API_KEY}",
        "COLLECTION_NAME": "antigravity-agent-memory",
        "EMBEDDING_PROVIDER": "fastembed"
      },
      "enabled": false
    },
    "daytona": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@daytona/mcp"
      ],
      "env": {
        "DAYTONA_API_KEY": "${DAYTONA_API_KEY}",
        "DAYTONA_SERVER_URL": "${DAYTONA_SERVER_URL}"
      },
      "enabled": false
    },
    "n8n": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "n8n-mcp"
      ],
      "env": {
        "N8N_API_KEY": "${N8N_API_KEY}",
        "N8N_BASE_URL": "${N8N_BASE_URL}"
      },
      "enabled": false
    },
    "postgres": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "postgresql-mcp"
      ],
      "env": {
        "POSTGRES_CONNECTION_STRING": "${POSTGRES_CONNECTION_STRING}"
      },
      "enabled": false
    },
    "firecrawl": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "firecrawl-mcp"
      ],
      "env": {
        "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}"
      },
      "enabled": false
    },
    "agentops": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "agentops-mcp"
      ],
      "env": {
        "AGENTOPS_API_KEY": "${AGENTOPS_API_KEY}"
      },
      "enabled": false
    },
    "chroma": {
      "transport": "stdio",
      "command": "uvx",
      "args": [
        "chroma-mcp",
        "--mode",
        "embedded",
        "--data-dir",
        "./.chroma"
      ],
      "enabled": false
    },
    "taskmaster-ai": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "--package=task-master-ai",
        "task-master-ai"
      ],
      "env": {
        "GEMINI_API_KEY": "${GEMINI_API_KEY}"
      },
      "enabled": false
    },
    "neon": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@neondatabase/mcp-server-neon"
      ],
      "env": {
        "NEON_API_KEY": "${NEON_API_KEY}"
      },
      "enabled": false
    },
    "openrouter": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "openrouter-mcp"
      ],
      "env": {
        "OPENROUTER_API_KEY": "${OPENROUTER_API_KEY}"
      },
      "enabled": false
    },
    "linear": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "linear-mcp-server"
      ],
      "env": {
        "LINEAR_API_KEY": "${LINEAR_API_KEY}"
      },
      "enabled": false
    },
    "notion": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@notionhq/notion-mcp-server"
      ],
      "env": {
        "NOTION_API_KEY": "${NOTION_API_KEY}"
      },
      "enabled": false
    },
    "docker-agent-gateway": {
      "transport": "sse",
      "url": "http://localhost:3000/api/control/stream",
      "enabled": true,
      "description": "Docker Open Agent Gateway (sandboxed.sh/docker-mcp multiplexer)"
    }
  }
}
